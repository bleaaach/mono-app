  createdAt: number;
}

// 时间块模板
interface TimeBlockTemplate {
  id: string;
  name: string;
  description?: string;
  blocks: Omit<TimeBlock, 'id' | 'date' | 'createdAt'>[];
  createdAt: number;
}

// 时间日志
interface TimeLog {
  id: string;
  entryId: string;
  content: string;
  tags?: string[];
  mood?: 'great' | 'good' | 'neutral' | 'tired' | 'bad';
  createdAt: number;
}

// 活动分组
interface ActivityGroup {
  id: string;
  name: string;
  color: string;
  order: number;
}

// 目标设置
interface Goal {
  id: string;
  activityId: string;
  targetDuration: number; // 每日目标时长（秒）
  daysOfWeek: number[]; // 生效的星期 [1,2,3,4,5]
}
