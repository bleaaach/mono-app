```typescript
// 活动类型
interface Activity {
  id: string;
  name: string;
  icon: string;
  color: string;
  groupId?: string;
  isArchived: boolean;
  createdAt: number;
}

// 时间记录
interface TimeEntry {
  id: string;
  activityId: string;
  startTime: number;
  endTime?: number;
  duration?: number; // 秒
  note?: string;
  createdAt: number;
}

// 时间块
interface TimeBlock {
  id: string;
  activityId: string;
  startTime: number; // 当天分钟数 0-1439
  endTime: number;   // 当天分钟数 0-1439
  date: string;      // YYYY-MM-DD
  isRecurring: boolean;
  recurringDays?: number[]; // [1,2,3,4,5] 周一到周五
