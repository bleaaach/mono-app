const checkTimeBlockConflict = (
  blocks: TimeBlock[],
  newBlock: Omit<TimeBlock, 'id' | 'createdAt'>
): boolean => {
  return blocks.some(block => 
    block.date === newBlock.date &&
    !(newBlock.endTime <= block.startTime || newBlock.startTime >= block.endTime)
  );
};

// 应用模板到指定日期
const applyTemplate = (
  template: TimeBlockTemplate,
  date: string
): TimeBlock[] => {
  return template.blocks.map(block => ({
    ...block,
    id: generateId(),
    date,
    createdAt: Date.now(),
  }));
};
